<Window x:Class="PSVR2Toolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PSVR2Toolkit.App"
        mc:Ignorable="d"
        Title="PSVR2 Toolkit" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Health Check">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        Driver Health Check
                    </TextBlock>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HealthCheckList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,10" Padding="10" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" FontSize="24" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                                <Setter Property="Text" Value="✓"/>
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Fail">
                                                                <Setter Property="Text" Value="✗"/>
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                <Setter Property="Text" Value="⚠"/>
                                                                <Setter Property="Foreground" Value="Orange"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="Bold" Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#666666" FontSize="11"/>
                                                <TextBlock Text="{Binding Message}" Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding FixSuggestion}" Foreground="#CC0000" FontStyle="Italic" Margin="0,5,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FixSuggestion}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" CornerRadius="4" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Margin="0,0,0,5">Controller Battery Status</TextBlock>
                                <TextBlock x:Name="BatteryStatusText" Text="Battery monitoring requires OpenVR.NET package" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Left Controller:" FontWeight="Bold" FontSize="11"/>
                                        <TextBlock x:Name="LeftBatteryText" Text="N/A" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Right Controller:" FontWeight="Bold" FontSize="11"/>
                                        <TextBlock x:Name="RightBatteryText" Text="N/A" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="HealthSummary" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button Content="Run Health Check" Padding="10,5" Click="RunHealthCheckButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Trigger Profiles">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        Adaptive Trigger Profiles
                    </TextBlock>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Profile:" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProfileComboBox" SelectionChanged="ProfileComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Controller:" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="LeftControllerRadio" Content="Left" GroupName="Controller" Margin="0,0,15,0" IsChecked="True"/>
                            <RadioButton x:Name="RightControllerRadio" Content="Right" GroupName="Controller" Margin="0,0,15,0"/>
                            <RadioButton x:Name="BothControllersRadio" Content="Both" GroupName="Controller"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="ApplyProfileButton" Content="Apply Profile" Padding="15,5" Margin="0,0,10,0" Click="ApplyProfileButton_Click"/>
                        <Button x:Name="TestProfileButton" Content="Live Test (1s)" Padding="15,5" Click="TestProfileButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" CornerRadius="4">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Current Effect:"/>
                            <TextBlock x:Name="CurrentEffectLabel" Text="None" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Gaze Debug">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        Real-Time Eye Tracking Data
                    </TextBlock>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,5,0" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" FontSize="14" Text="Left Eye" Margin="0,0,0,10"/>

                                    <TextBlock Text="Gaze Origin (mm):" FontWeight="Bold" Margin="0,5,0,2"/>
                                    <TextBlock x:Name="LeftGazeOrigin" Text="N/A"/>

                                    <TextBlock Text="Gaze Direction:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftGazeDirection" Text="N/A"/>

                                    <TextBlock Text="Pupil Diameter (mm):" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftPupilDiameter" Text="N/A"/>

                                    <TextBlock Text="Pupil Position in Sensor:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftPupilPosition" Text="N/A"/>

                                    <TextBlock Text="Position Guide:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftPosGuide" Text="N/A"/>

                                    <TextBlock Text="Blink:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftBlink" Text="N/A"/>

                                    <TextBlock Text="Openness:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="LeftOpenness" Text="N/A"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="5,0,0,0" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" FontSize="14" Text="Right Eye" Margin="0,0,0,10"/>

                                    <TextBlock Text="Gaze Origin (mm):" FontWeight="Bold" Margin="0,5,0,2"/>
                                    <TextBlock x:Name="RightGazeOrigin" Text="N/A"/>

                                    <TextBlock Text="Gaze Direction:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightGazeDirection" Text="N/A"/>

                                    <TextBlock Text="Pupil Diameter (mm):" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightPupilDiameter" Text="N/A"/>

                                    <TextBlock Text="Pupil Position in Sensor:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightPupilPosition" Text="N/A"/>

                                    <TextBlock Text="Position Guide:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightPosGuide" Text="N/A"/>

                                    <TextBlock Text="Blink:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightBlink" Text="N/A"/>

                                    <TextBlock Text="Openness:" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock x:Name="RightOpenness" Text="N/A"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button x:Name="PauseResumeButton" Content="Pause" Padding="15,5" Click="PauseResumeButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Eye Calibration">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        Eye Tracking Calibration
                    </TextBlock>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="4" Background="#F5F5F5">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                <Bold>What is calibration?</Bold>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                Eye tracking calibration improves gaze accuracy by measuring the offset between where you look and where the headset thinks you're looking. This process takes about 1-2 minutes.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                <Bold>When to calibrate:</Bold>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap">
                                • First time using eye tracking
                                • After adjusting headset fit
                                • If gaze feels inaccurate in games
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Button x:Name="LaunchCalibrationButton" Content="Launch Calibration Tool" Padding="15,8" FontSize="14" FontWeight="Bold" Click="LaunchCalibrationButton_Click" Margin="0,0,0,10"/>
                        <Button x:Name="ClearCalibrationButton" Content="Clear Calibration" Padding="10,5" Click="ClearCalibrationButton_Click" Margin="0,0,0,15"/>

                        <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" CornerRadius="4" Background="#F0F8FF">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Margin="0,0,0,5">Eye Tracking Cursor Control</TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#666666">
                                    Use your eye gaze to control the Windows mouse cursor. Useful for desktop VR and accessibility.
                                </TextBlock>
                                <CheckBox x:Name="GazeCursorCheckBox" Content="Enable Gaze Cursor" Margin="0,0,0,10" Checked="GazeCursorCheckBox_Checked" Unchecked="GazeCursorCheckBox_Unchecked"/>
                                <TextBlock Text="Sensitivity:" Margin="0,5,0,2"/>
                                <Slider x:Name="CursorSensitivitySlider" Minimum="0.1" Maximum="5.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,5" ValueChanged="CursorSettings_Changed"/>
                                <TextBlock Text="Smoothing:" Margin="0,5,0,2"/>
                                <Slider x:Name="CursorSmoothingSlider" Minimum="0.0" Maximum="1.0" Value="0.3" TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,0,0,5" ValueChanged="CursorSettings_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" CornerRadius="4">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Calibration Status" Margin="0,0,0,10"/>

                            <TextBlock Text="Calibration File:" FontWeight="Bold" Margin="0,5,0,2"/>
                            <TextBlock x:Name="CalibrationFilePathLabel" Text="N/A" Foreground="#666666"/>

                            <TextBlock Text="Last Calibrated:" FontWeight="Bold" Margin="0,10,0,2"/>
                            <TextBlock x:Name="CalibrationDateLabel" Text="Never" Foreground="#666666"/>

                            <TextBlock Text="Current Offsets:" FontWeight="Bold" Margin="0,10,0,2"/>
                            <TextBlock x:Name="CalibrationOffsetsLabel" Text="X: 0.000, Y: 0.000" Foreground="#666666"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Headset Haptics">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        Headset Haptic Feedback
                    </TextBlock>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="4" Background="#F5F5F5">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                <Bold>About Headset Haptics</Bold>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                The PSVR2 headset contains a haptic motor in the headband that can produce vibration feedback. Use the controls below to test and configure the headset haptic effect.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#666666" FontStyle="Italic">
                                Requires IPC server version 5 or later.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Amplitude (motor strength):" FontWeight="Bold" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="HapticAmplitudeSlider" Grid.Column="0" Minimum="0" Maximum="255" Value="128"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="HapticSlider_ValueChanged"/>
                            <TextBlock x:Name="HapticAmplitudeLabel" Grid.Column="1" Text="128"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Frequency (Hz):" FontWeight="Bold" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="HapticFrequencySlider" Grid.Column="0" Minimum="0" Maximum="255" Value="50"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="HapticSlider_ValueChanged"/>
                            <TextBlock x:Name="HapticFrequencyLabel" Grid.Column="1" Text="50"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TestHapticButton" Content="Test Haptic (1s)" Padding="15,5" Margin="0,0,10,0" Click="TestHapticButton_Click"/>
                            <Button x:Name="StopHapticButton" Content="Stop Haptic" Padding="15,5" Click="StopHapticButton_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" CornerRadius="4">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Current Haptic Status:"/>
                            <TextBlock x:Name="HapticStatusLabel" Text="Idle" Margin="0,5,0,0" Foreground="#666666"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
