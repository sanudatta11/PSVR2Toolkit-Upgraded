{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Restore (NuGet/MSBuild)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/restore.ps1"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1",
        "-Configuration",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "Restore (NuGet/MSBuild)",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build ReleaseCI",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1",
        "-Configuration",
        "ReleaseCI"
      ],
      "group": "build",
      "dependsOn": "Restore (NuGet/MSBuild)",
      "problemMatcher": "$msCompile"
    }
  ]
}
